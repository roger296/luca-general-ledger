# ─────────────────────────────────────────────────────────────────────────────
# Luca General Ledger — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Security (generate with: openssl rand -base64 48) ────────────────────────
# REQUIRED: Change this before going live. Use a long random string.
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_48
JWT_EXPIRES_IN=24h

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=gl_ledger
POSTGRES_USER=gl_admin
# REQUIRED: Change this to a strong password
POSTGRES_PASSWORD=CHANGE_ME_strong_database_password

# ── Chain storage ─────────────────────────────────────────────────────────────
# Path inside the container where chain files are stored (backed by a Docker volume)
CHAIN_DIR=/data/chains

# ── Webhooks ──────────────────────────────────────────────────────────────────
ESCALATION_HOURS=48

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Development only ─────────────────────────────────────────────────────────
# API key bypass for development/testing. Remove or leave blank in production.
# DEV_API_KEY=dev
